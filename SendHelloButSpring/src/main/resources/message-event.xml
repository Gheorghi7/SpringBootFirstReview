<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">
    <bean id="message" class="org.example.eventhandling1.Message">
        <property name="message" value="This is simple message."/>
    </bean>
    <bean id="start"
          class="org.example.eventhandling1.EventStartHandling"/>
    <bean id="stop"
          class="org.example.eventhandling1.EventStopHandling"/>
</beans>